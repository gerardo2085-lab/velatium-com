---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/archive', label: 'Archive' },
  { href: '/books', label: 'Books' },
  { href: '/about', label: 'About' },
  { href: '/subscribe', label: 'Subscribe' },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="nav-logo-mark">THE</span>
      <span class="nav-logo-name">VELATIUM</span>
    </a>

    <div class="nav-links" id="nav-links">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://www.youtube.com/@TheVelatium"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-cta"
      >
        Watch ▶
      </a>
    </div>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200, 169, 81, 0.12);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    flex-shrink: 0;
  }

  .nav-logo-mark {
    font-family: var(--cinzel);
    font-size: 9px;
    letter-spacing: 0.5em;
    color: var(--gold);
    opacity: 0.6;
  }

  .nav-logo-name {
    font-family: var(--cinzel);
    font-size: 17px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.12em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--lato);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted2);
    padding: 6px 12px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    border-bottom-color: var(--gold);
  }

  .nav-cta {
    font-family: var(--cinzel);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--gold);
    border: 1px solid rgba(200, 169, 81, 0.4);
    padding: 7px 16px;
    margin-left: 12px;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-cta:hover {
    background: rgba(200, 169, 81, 0.08);
    border-color: var(--gold);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: all 0.25s;
    transform-origin: center;
  }

  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 768px) {
    .nav-hamburger { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: rgba(10, 10, 10, 0.98);
      border-bottom: 1px solid rgba(200, 169, 81, 0.12);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 12px 0 20px;
    }

    .nav-links.open { display: flex; }

    .nav-link {
      width: 100%;
      padding: 12px 32px;
      border-bottom: none;
      border-left: 2px solid transparent;
    }

    .nav-link.active,
    .nav-link:hover {
      border-bottom: none;
      border-left-color: var(--gold);
      background: rgba(200, 169, 81, 0.04);
    }

    .nav-cta {
      margin: 12px 32px 0;
      text-align: center;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    navLinks?.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!hamburger?.contains(e.target as Node) && !navLinks?.contains(e.target as Node)) {
      hamburger?.classList.remove('open');
      navLinks?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
