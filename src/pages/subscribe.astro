---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const year = new Date().getFullYear();
---

<Base
  title="Subscribe"
  description="The Velatium Chronicle is a weekly newsletter covering suppressed history, lost civilizations, and the truth institutions prefer you never find. One story. Every week. Free."
>
  <Nav />

  <div class="page">

    <!-- LEFT — Conviction -->
    <div class="left">
      <p class="eyebrow">The Velatium Chronicle</p>
      <h1 class="conviction-headline">
        The inbox is full of noise.<br>
        <em>This is the signal.</em>
      </h1>
      <p class="conviction-body">
        Every week, <strong>one story</strong> — sourced from archives, declassified documents, and primary records. Not opinion. Not commentary. <strong>What actually happened.</strong> And why the version you were taught looks nothing like it.
      </p>

      <ul class="preview-list">
        <li class="preview-item">
          <div class="preview-icon"></div>
          <p class="preview-text"><strong>One deep story per week.</strong> Cuba before Castro. The scientists who built NASA. The council that decided your Bible. Written like a documentary. Sourced like an archive.</p>
        </li>
        <li class="preview-item">
          <div class="preview-icon"></div>
          <p class="preview-text"><strong>"What didn't fit in the video."</strong> Every issue includes material cut from the episode — the detail too specific for YouTube, too important to discard.</p>
        </li>
        <li class="preview-item">
          <div class="preview-icon"></div>
          <p class="preview-text"><strong>Bilingual. Permanent. Yours.</strong> English and Spanish editions. No algorithm between you and the story. No paywall. No ad reads. Ever.</p>
        </li>
      </ul>

      <p class="trust-line">No spam. No affiliate links. Unsubscribe in one click. The history they buried — delivered weekly.</p>
    </div>

    <!-- RIGHT — Form -->
    <div class="right">
      <p class="form-eyebrow">Free. Weekly. Permanent.</p>
      <h2 class="form-headline">Join the readers who stopped trusting the official version.</h2>
      <p class="form-sub">One email. Every week. History that didn't make the textbooks — and the archives that prove it.</p>

      <div class="sample">
        <div class="sample-tag">Latest Issue — Sample</div>
        <div class="sample-title">The Council of Nicaea: Who Decided What Goes in the Bible?</div>
        <div class="sample-body">In 325 AD, 318 bishops gathered in a Roman resort town. What they decided shaped two billion lives. What they argued about — and what they discarded — you were never told...</div>
      </div>

      <div id="formWrap">
        <form class="sub-form" id="subForm">
          <div class="input-wrap">
            <input type="email" class="sub-input" id="emailInput"
              placeholder="your@email.com" required autocomplete="email" />
          </div>
          <div class="form-error" id="formError">Something went wrong. Please try again.</div>
          <button type="submit" class="sub-btn">Join the Chronicle</button>
          <p class="form-note">Free forever · No spam · Unsubscribe anytime</p>
        </form>
      </div>

      <div class="success-msg" id="successMsg">
        <span class="success-glyph">✦</span>
        <div class="success-title">You're in the archive now.</div>
        <p class="success-sub">Your first issue arrives this week. Check your inbox — or your spam folder, if you've been trained to bury inconvenient truths.</p>
      </div>
    </div>

  </div>

  <footer>
    <span class="footer-brand">The Velatium</span>
    <ul class="footer-links">
      <li><a href="/archive">Archive</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/books">Books</a></li>
      <li><a href="https://www.youtube.com/@TheVelatium" target="_blank" rel="noopener">YouTube</a></li>
    </ul>
    <span class="footer-copy">© {year} The Velatium. All rights reserved.</span>
  </footer>

</Base>

<script>
  const SUBSCRIBE_ENDPOINT = '/webhook/subscribe-en';

  document.getElementById('subForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('emailInput') as HTMLInputElement).value.trim();
    const btn   = (e.target as HTMLFormElement).querySelector('.sub-btn') as HTMLButtonElement;
    const err   = document.getElementById('formError');
    err?.classList.remove('show');
    btn.textContent = 'Sending…';
    btn.disabled = true;

    try {
      const res = await fetch(SUBSCRIBE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      if (res.ok) {
        (document.getElementById('formWrap') as HTMLElement).style.display = 'none';
        document.getElementById('successMsg')?.classList.add('show');
      } else {
        throw new Error('Bad response');
      }
    } catch {
      err?.classList.add('show');
      btn.textContent = 'Join the Chronicle';
      btn.disabled = false;
    }
  });
</script>

<style>
  .page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 60px;
  }

  .left {
    padding: 80px 64px 80px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgba(200,169,81,0.1);
    position: relative;
  }
  .left::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 0% 50%, rgba(200,169,81,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .eyebrow {
    font-family: var(--lato);
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.42em; text-transform: uppercase;
    color: var(--gold); opacity: 0.8;
    margin-bottom: 24px;
  }

  .conviction-headline {
    font-family: var(--cinzel);
    font-size: clamp(28px, 3vw, 46px);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: 0.02em;
    margin-bottom: 32px;
  }
  .conviction-headline em { color: var(--gold); font-style: normal; }

  .conviction-body {
    font-family: var(--lato);
    font-size: 16px;
    color: rgba(232,224,208,0.72);
    line-height: 1.85;
    margin-bottom: 48px;
    max-width: 480px;
  }
  .conviction-body strong { color: var(--text); font-weight: 700; }

  .preview-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 48px;
  }
  .preview-item { display: flex; align-items: flex-start; gap: 14px; }
  .preview-icon {
    width: 20px; height: 20px;
    border: 1px solid rgba(200,169,81,0.5);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .preview-icon::after {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }
  .preview-text {
    font-family: var(--lato);
    font-size: 14px;
    color: rgba(232,224,208,0.75);
    line-height: 1.55;
  }
  .preview-text strong { color: var(--text); }

  .trust-line {
    font-family: var(--lato);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-style: italic;
    padding-top: 24px;
    border-top: 1px solid rgba(200,169,81,0.1);
  }

  .right {
    padding: 80px 80px 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }
  .right::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 50% at 100% 60%, rgba(192,57,43,0.05) 0%, transparent 65%);
    pointer-events: none;
  }

  .form-eyebrow {
    font-family: var(--lato);
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.42em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 20px;
  }
  .form-headline {
    font-family: var(--cinzel);
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .form-sub {
    font-family: var(--lato);
    font-size: 14px;
    color: var(--muted2);
    line-height: 1.65;
    margin-bottom: 40px;
  }

  .sample {
    background: #0F0F12;
    border: 1px solid rgba(200,169,81,0.15);
    border-left: 3px solid var(--gold);
    padding: 20px 22px;
    margin-bottom: 36px;
  }
  .sample-tag {
    font-family: var(--lato);
    font-size: 8px; font-weight: 700;
    letter-spacing: 0.35em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 8px;
  }
  .sample-title {
    font-family: var(--cinzel);
    font-size: 14px; font-weight: 600;
    color: var(--text); margin-bottom: 6px;
    line-height: 1.3;
  }
  .sample-body {
    font-family: var(--lato);
    font-size: 13px;
    color: var(--muted2);
    line-height: 1.6;
  }

  .sub-form { display: flex; flex-direction: column; gap: 0; }
  .input-wrap { position: relative; margin-bottom: 12px; }
  .sub-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(200,169,81,0.3);
    padding: 14px 0;
    font-family: var(--lato);
    font-size: 16px;
    color: var(--text);
    outline: none;
    transition: border-color var(--t);
    letter-spacing: 0.02em;
  }
  .sub-input::placeholder { color: var(--muted); font-size: 15px; }
  .sub-input:focus { border-bottom-color: var(--gold); }

  .sub-btn {
    width: 100%;
    background: var(--red);
    border: none;
    padding: 16px 32px;
    font-family: var(--cinzel);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    cursor: pointer;
    margin-top: 8px;
    transition: background var(--t), transform var(--t);
  }
  .sub-btn:hover { background: #a93226; transform: translateY(-1px); }

  .form-note {
    font-family: var(--lato);
    font-size: 11px;
    color: var(--muted);
    text-align: center;
    margin-top: 14px;
    letter-spacing: 0.04em;
  }

  .form-error {
    font-family: var(--lato);
    font-size: 12px;
    color: #e74c3c;
    margin-top: 8px;
    display: none;
  }
  .form-error.show { display: block; }

  .success-msg { display: none; text-align: center; padding: 40px 0; }
  .success-msg.show { display: block; }
  .success-glyph {
    font-family: var(--cinzel);
    font-size: 32px;
    color: var(--gold);
    display: block;
    margin-bottom: 16px;
  }
  .success-title {
    font-family: var(--cinzel);
    font-size: 20px;
    color: var(--text);
    margin-bottom: 10px;
  }
  .success-sub {
    font-family: var(--lato);
    font-size: 14px;
    color: var(--muted2);
    line-height: 1.6;
  }

  footer {
    border-top: 1px solid rgba(200,169,81,0.12);
    padding: 36px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-brand {
    font-family: var(--cinzel); font-size: 11px;
    font-weight: 600; letter-spacing: 0.3em;
    color: var(--gold); text-transform: uppercase;
  }
  .footer-links { display: flex; gap: 20px; list-style: none; flex-wrap: wrap; }
  .footer-links a {
    font-family: var(--lato); font-size: 12px;
    color: var(--muted); text-decoration: none;
    transition: color var(--t);
  }
  .footer-links a:hover { color: var(--gold); }
  .footer-copy { font-family: var(--lato); font-size: 11px; color: var(--muted); }

  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; }
    .left { padding: 60px 32px 48px; border-right: none; border-bottom: 1px solid rgba(200,169,81,0.1); }
    .right { padding: 48px 32px 60px; }
  }
  @media (max-width: 768px) {
    nav { padding: 0 24px; }
    footer { flex-direction: column; text-align: center; }
  }
</style>
