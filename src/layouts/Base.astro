---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  includeD3?: boolean;
}

const {
  title,
  description = 'The history they buried. The truth you deserve.',
  ogImage = '/images/og-default.jpg',
  lang = 'en',
  includeD3 = false
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | The Velatium</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={`${title} | The Velatium`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lato:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet" />
  {includeD3 && (
    <>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js" is:inline></script>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/topojson/3.0.2/topojson.min.js" is:inline></script>
    </>
  )}
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg:     #0A0A0A;
      --purple: #1A0F2E;
      --text:   #E8E0D0;
      --gold:   #C8A951;
      --red:    #C0392B;
      --muted:  #6B5A4E;
      --muted2: #8A7A6A;
      --cinzel: 'Cinzel', serif;
      --lato:   'Lato', sans-serif;
      --t:      220ms ease;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--lato);
      min-height: 100vh;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
