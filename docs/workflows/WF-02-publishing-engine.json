          "reply_markup": "={{ JSON.stringify({ \"inline_keyboard\": [ [ { \"text\": \"✅ Approve & Publish\", \"url\": $execution.resumeUrl + \"?action=approve\" }, { \"text\": \"❌ Reject\", \"url\": $execution.resumeUrl + \"?action=reject\" } ] ] }) }}"
