      "parameters": {
        "jsCode": "// Extract base64 image data from the binary download\nconst item = $input.first();\nconst binaryKey = Object.keys(item.binary || {})[0] || 'data';\nconst imageB64 = item.binary?.[binaryKey]?.data || '';\nif (!imageB64) throw new Error('No binary data received for thumbnail');\n\nconst slug = $('Build Episode JSON').first().json.slug;\n\nreturn [{ json: { slug, imageB64 } }];"
