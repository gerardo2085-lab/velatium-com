    {
      "id": "d1a2b3c4-0011-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Build Episode JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 0],
      "parameters": {
        "jsCode": "// Reconstruct episode data from the Merge Preprocess Data node\nconst ep = $('Merge Preprocess Data').first().json;\n\n// Build clean episode JSON (matches the required schema)\nconst episodeJson = {\n  slug: ep.slug,\n  title: ep.title,\n  pillar: ep.pillar,\n  pillarLabel: ep.pillarLabel,\n  language: ep.language,\n  date: ep.date,\n  duration: ep.duration,\n  youtube_id: ep.youtube_id,\n  spotify_id: ep.spotify_id,\n  thumbnail: ep.thumbnail,\n  lat: ep.lat,\n  lng: ep.lng,\n  article_years: ep.article_years,\n  quick_answer: ep.quick_answer,\n  article_body: ep.article_body,\n  kdp_link: ep.kdp_link\n};\n\n// Remove empty optional fields to keep JSON clean\nif (!episodeJson.spotify_id) delete episodeJson.spotify_id;\nif (!episodeJson.kdp_link) delete episodeJson.kdp_link;\nif (!episodeJson.duration) delete episodeJson.duration;\n\nconst episodeJsonStr = JSON.stringify(episodeJson, null, 2);\nconst episodeJsonB64 = Buffer.from(episodeJsonStr).toString('base64');\n\n// _latest.json is a minimal summary (no article_body to keep it lightweight)\nconst latestJson = {\n  slug: ep.slug,\n  title: ep.title,\n  pillar: ep.pillar,\n  pillarLabel: ep.pillarLabel,\n  language: ep.language,\n  date: ep.date,\n  duration: ep.duration,\n  youtube_id: ep.youtube_id,\n  thumbnail: ep.thumbnail,\n  lat: ep.lat,\n  lng: ep.lng,\n  article_years: ep.article_years,\n  quick_answer: ep.quick_answer,\n  kdp_link: ep.kdp_link\n};\nif (!latestJson.kdp_link) delete latestJson.kdp_link;\nif (!latestJson.duration) delete latestJson.duration;\n\nconst latestJsonStr = JSON.stringify(latestJson, null, 2);\nconst latestJsonB64 = Buffer.from(latestJsonStr).toString('base64');\n\nreturn [{\n  json: {\n    slug: ep.slug,\n    title: ep.title,\n    pillar: ep.pillar,\n    language: ep.language,\n    txtFileId: ep.txtFileId,\n    parentId: ep.parentId,\n    textContent: ep.textContent,\n    episodeJsonB64,\n    latestJsonB64\n  }\n}];"
      }
    },
