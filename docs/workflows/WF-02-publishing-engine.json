        }
      }
    },
    {
      "id": "d1a2b3c4-0003-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Extract Slug",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 200],
      "parameters": {
        "jsCode": "const item = $input.first();\nconst fileName = item.json.name;\nconst slug = fileName.replace(/\\.txt$/i, '').trim();\nconst txtFileId = item.json.id;\nconst parentId = item.json.parents?.[0] || '';\n\nif (!slug || !txtFileId) {\n  throw new Error('Could not extract slug or file ID from: ' + fileName);\n}\n\nreturn [{ json: { slug, txtFileId, parentId, fileName } }];"
      }
    },
    {
      "id": "d1a2b3c4-0004-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Download .txt",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [720, 200],
      "parameters": {
        "resource": "file",
        "operation": "download",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.txtFileId }}",
          "mode": "id"
        },
        "options": {}
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_OAUTH_CRED_ID",
          "name": "Google Drive"
        }
      }
    },
    {
      "id": "d1a2b3c4-0005-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Read Text Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 200],
      "parameters": {
        "jsCode": "// Retrieve slug from the Extract Slug node (Drive Download does not pass JSON through)\nconst slugData = $('Extract Slug').first().json;\nconst slug = slugData.slug;\nconst txtFileId = slugData.txtFileId;\nconst parentId = slugData.parentId;\n\n// Extract text from binary download\nconst item = $input.first();\nconst binaryKey = Object.keys(item.binary || {})[0] || 'data';\nconst b64 = item.binary?.[binaryKey]?.data || '';\nif (!b64) throw new Error('No binary data received from Drive download');\n\nconst textContent = Buffer.from(b64, 'base64').toString('utf-8');\n\nreturn [{ json: { slug, txtFileId, parentId, textContent } }];"
      }
    },
    {
      "id": "d1a2b3c4-0006-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Call Preprocess",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 200],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8200/preprocess",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"content\": {{ JSON.stringify($json.textContent) }},\n  \"filename\": {{ JSON.stringify($json.slug + '.txt') }}\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      }
    },
    {
      "id": "d1a2b3c4-0007-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Merge Preprocess Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 200],
      "parameters": {
        "jsCode": "// Merge preprocess results with slug data\nconst slugData = $('Read Text Content').first().json;\nconst preprocess = $input.first().json;\n\n// Validate required pillar values\nconst VALID_PILLARS = ['latin-america', 'forbidden-history', 'lost-civilizations', 'god-power'];\nconst PILLAR_LABELS = {\n  'latin-america': 'Latinoamérica Sin Censura',\n  'forbidden-history': 'Forbidden History',\n  'lost-civilizations': 'Lost Civilizations',\n  'god-power': 'God & Power'\n};\nconst PILLAR_LANGUAGE = {\n  'latin-america': 'es',\n  'forbidden-history': 'en',\n  'lost-civilizations': 'en',\n  'god-power': 'en'\n};\n\nconst pillar = preprocess.pillar || '';\nif (!VALID_PILLARS.includes(pillar)) {\n  throw new Error(`Invalid pillar '${pillar}'. Must be one of: ${VALID_PILLARS.join(', ')}`);\n}\n\n// Build the date string (today)\nconst now = new Date();\nconst dateStr = now.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });\n\n// KDP link: only for latin-america pillar\nconst kdpLink = (pillar === 'latin-america') ? 'https://a.co/d/01bFuDNp' : (preprocess.kdp_link || '');\n\nconst episodeData = {\n  slug: slugData.slug,\n  title: preprocess.title || '',\n  pillar: pillar,\n  pillarLabel: PILLAR_LABELS[pillar],\n  language: PILLAR_LANGUAGE[pillar],\n  date: dateStr,\n  duration: preprocess.duration || '',\n  youtube_id: preprocess.youtube_id || '',\n  spotify_id: preprocess.spotify_id || '',\n  thumbnail: `/images/episodes/${slugData.slug}.jpeg`,\n  lat: preprocess.lat || 0,\n  lng: preprocess.lng || 0,\n  article_years: preprocess.article_years || [],\n  quick_answer: preprocess.quick_answer || '',\n  article_body: preprocess.article_body || '',\n  kdp_link: kdpLink\n};\n\nreturn [{\n  json: {\n    ...episodeData,\n    txtFileId: slugData.txtFileId,\n    parentId: slugData.parentId,\n    textContent: slugData.textContent\n  }\n}];"
      }
    },
    {
      "id": "d1a2b3c4-0008-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Send Telegram Approval",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
