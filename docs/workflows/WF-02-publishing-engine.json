      "id": "d1a2b3c4-0002-4e5f-a6b7-c8d9e0f1a2b3",
      "name": "Filter: .txt only",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [240, 200],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
